{
  "name": "locklens",
  "version": "1.1.3",
  "main": "build/client.js",
  "bin": {
    "locklens": "build/client.js"
  },
  "exports": {
    ".": "./build/client.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "commitlint": "commitlint",
    "start": "yarn build && node build/client.js",
    "release": "node scripts/release.mjs",
    "test:cli": "yarn build && node --test tests/cli",
    "test:manual:local": "npx tsx src/tests/audit-local-manual-test.ts",
    "test:manual:remote": "npx tsx src/tests/audit-remote-manual-test.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn test:cli"
  },
  "keywords": [
    "lockfile",
    "audit",
    "security",
    "mcp",
    "cli",
    "npm",
    "yarn",
    "pnpm",
    "dependencies"
  ],
  "author": "chenglin",
  "license": "MIT",
  "homepage": "https://github.com/BARMPlus/locklens#readme",
  "bugs": {
    "url": "https://github.com/BARMPlus/locklens/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BARMPlus/locklens.git"
  },
  "description": "Audit npm, Yarn, and pnpm lockFiles as both an MCP server and a CLI tool.",
  "files": [
    "build",
    "README.md",
    "README-en_US.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "audit-ci": "^7.1.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "standard-version": "^9.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,mjs,cjs}": "eslint --fix"
  }
}
